# ══ REQUIRED ══════════════════════════════════════════════════
# Set ALL of these before running npm run dev or deploying.

# Site URL — used for metadataBase, OG images, canonical URLs
NEXT_PUBLIC_SITE_URL="https://sumitkolgire.com"

# Supabase — Auth + Database (get from supabase.com → project → settings → API)
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""    # NEVER expose publicly

# Database — Direct connection (use port 6543 / pgbouncer on Vercel serverless)
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# Sanity CMS — get from sanity.io → manage → project settings
NEXT_PUBLIC_SANITY_PROJECT_ID=""
NEXT_PUBLIC_SANITY_DATASET="production"
NEXT_PUBLIC_SANITY_API_VERSION="2024-01-01"
SANITY_API_TOKEN=""             # Read-only token for ISR fetches

# IP Hashing (REQUIRED in prod — generate with: openssl rand -hex 32)
IP_HASH_SALT=""

# ══ OPTIONAL SERVICES ══════════════════════════════════════════

# Upstash Redis — rate limiting (free tier at upstash.com)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Resend — newsletter emails (free 3k/month at resend.com)
RESEND_API_KEY=""
RESEND_FROM_EMAIL="hello@sumitkolgire.com"

# Anthropic — AI private tools in lab
ANTHROPIC_API_KEY=""

# Cloudinary — image hosting (free tier)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""

# ISR Revalidation secret (openssl rand -hex 32)
REVALIDATE_SECRET=""
